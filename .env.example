NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# TextBubbles (iMessage Integration)
# Get your API key from TextBubbles dashboard
TEXTBUBBLES_API_KEY=your-textbubbles-api-key
# Your TextBubbles phone number (iMessage-enabled)
TEXTBUBBLES_PHONE_NUMBER=+1234567890
# Webhook secret for verifying incoming webhooks (generate with: openssl rand -hex 32)
TEXTBUBBLES_WEBHOOK_SECRET=your-webhook-secret
